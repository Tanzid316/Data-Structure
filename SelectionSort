#include<bits/stdc++.h>
using namespace std;

vector <int> vec;

void SelectionSort()
{
    int temp, minIndex, i, j;
    for(i = 0; i < vec.size(); i++)
    {
        minIndex = i;

        for(j = i + 1; j < 5; j++)
        {
            if(vec[minIndex] > vec[j])
            {
                minIndex = j;
            }
        }

        temp = vec[i];
        vec[i] = vec[minIndex];
        vec[minIndex] = temp;
    }

    for(i = 0; i < vec.size(); i++)
    {
        printf("%d ", vec[i]);
    }

}

int main()
{
    int i,n,x;

    cin>>n;

    for(i=0; i<n; i++)
    {
        cin>>x;
        vec.push_back(x);
    }

    SelectionSort();

    return 0;
}
