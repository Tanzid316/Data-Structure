
#include<bits/stdc++.h>
using namespace std;
vector <int> vec;

void binarySearch(int key)
{
    int high,low,mid,flag=0,store;
    low = 0;
    high = vec.size()-1;
    while(low<=high)
    {
        mid = low + (high-low)/2;
        if(vec[mid] == key)
        {
            flag = 0;
            store = mid;
            break;
        }
        else if (vec[mid] < key)
        {
            low = mid + 1;
        }
        else if (vec[mid] > key)
        {
            high = mid - 1;
        }
        
    }
    if(low>high)
    {
        cout<<"Not found."<<endl;
        flag = 1;
    }
    if(flag == 0)
    cout<<"Here your index number = "<<store<<endl;
}

int main()
{
    int x,i,n,key;
    cout<<"Enter the input number : ";
    cin>>n;

    for(i=0; i<n; i++)
    {
        cin>>x;
        vec.push_back(x);
    }

    sort(vec.begin(), vec.end()); //for sorting in ascending order.

    cout<<"Enter the key : ";
    cin>>key;
    binarySearch(key);
    return 0;
}


