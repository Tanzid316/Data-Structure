#include<bits/stdc++.h>
using namespace std;

int binarySearch(vector<int> vec, int target) {
    int low = 0, high = vec.size() - 1;
    while (low <= high) {
        int mid = low + (high - low) / 2;
        if (vec[mid] == target) {
            return mid;
        } else if (vec[mid] < target) {
            low = mid + 1;
        } else {
            high = mid - 1;
        }
    }
    return -1;
}

int lowerBound(vector<int> vec, int key)
{
    int low,mid,high,ans;
    low = 0;
    high = vec.size() - 1;
    ans = vec.size();

    while(low<=high)
    {
        mid = low + (high-low)/2;
        if(vec[mid] >= key)
        {
            ans = mid;
            high = mid - 1;
        }
        else
        {
            low = mid + 1;
        }
    }
    return ans;
}

int upperBound(vector <int> vec, int key)
{
    int low,mid,high,ans;
    low = 0;
    high = vec.size()-1;
    ans = vec.size();

    while(low<=high)
    {
        mid = low + (high-low)/2;
        if(vec[mid] > key)
        {
            ans = mid;
            high = mid - 1;
        }
        else
        {
            low = mid + 1;
        }
    }
    return ans;
}
int main() {
    int n;
    cin >> n;

    vector<int> vec;
    for (int i = 0; i < n; i++) {
        int x;
        cin >> x;
        vec.push_back(x);
    }

    int key;
    cin >> key;


    int searchResult = binarySearch(vec, key);
    int lb = lowerBound(vec, key);
    int ub = upperBound(vec, key);


    if (searchResult != -1) {
        cout << "Book Found" << endl;
    } else {
        cout << "Book Not Found" << endl;
    }

    cout << "Lower Bound Index: " << lb << endl;
    cout << "Upper Bound Index: " << ub << endl;

    return 0;
}
